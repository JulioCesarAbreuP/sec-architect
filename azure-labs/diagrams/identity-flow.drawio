<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="Identity Flow" id="identity-flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1" pageScale="1"
                  pageWidth="1654" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Identity Flow — Managed Identity Authentication" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="427" y="20" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- Steps -->
        <mxCell id="s1" value="1. Workload requests token&#xa;from IMDS endpoint&#xa;(169.254.169.254)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="2. Azure Instance Metadata&#xa;Service (IMDS)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="120" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="3. Microsoft Entra ID&#xa;issues OAuth 2.0&#xa;access token (JWT)" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="120" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s4" value="4. Token returned to&#xa;workload (cached)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="280" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="5. Workload calls&#xa;Key Vault / Storage&#xa;with Bearer token" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="400" y="280" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="6. Resource validates&#xa;token against Entra ID&#xa;+ checks RBAC role" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="220" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="s7" value="7. Access Granted ✓&#xa;(Least-Privilege RBAC)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="100" y="440" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- No passwords label -->
        <mxCell id="note" value="No passwords, certificates, or&#xa;connection strings in code or config." style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="440" width="250" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s1" target="s2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s2" target="s3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s3" target="s4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s4" target="s5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s5" target="s6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s6" target="s7" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
